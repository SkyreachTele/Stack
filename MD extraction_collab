# This function will be executed by each worker process in the pool
def process_single_file(file_path):
    """Processes a single file to extract and clean content."""
    # Converters must be instantiated within each worker process to avoid sharing issues
    from docling.document_converter import DocumentConverter
    from markitdown import MarkItDown
    docling_converter_worker = DocumentConverter()
    markitdown_converter_worker = MarkItDown()

    ext = file_path.lower().split('.')[-1]
    raw = ""
    processed_content = None
    error_message = None

    try:
        # ROUTING LOGIC INCLUDING MINERU
        if ext == 'pdf':
            print(f"  └─ MinerU Extracting: {os.path.basename(file_path)} (PID: {os.getpid()})")

            # Generate a unique temporary output directory for each process and file
            file_identifier = os.path.basename(file_path).replace('.', '_')
            temp_output_dir = os.path.join('/content/temp_miner_output', f"{file_identifier}_{os.getpid()}_{datetime.datetime.now().microsecond}")
            os.makedirs(temp_output_dir, exist_ok=True)

            try:
                # Using Magic-PDF command line via os for stability in Colab
                os.system(f"magic-pdf -i '{file_path}' -o '{temp_output_dir}' -m json")

                miner_output_md = None
                # MinerU often puts output in a subfolder. Search for the .md file.
                for root_walk, _, files_walk in os.walk(temp_output_dir):
                    for f_walk in files_walk:
                        if f_walk.endswith('.md'):
                            miner_output_md = os.path.join(root_walk, f_walk)
                            break
                    if miner_output_md:
                        break

                if miner_output_md and os.path.exists(miner_output_md):
                    with open(miner_output_md, 'r', encoding='utf-8') as f:
                        raw = f.read()
                else:
                    print(f"  └─ MinerU did not produce expected MD for {os.path.basename(file_path)} (PID: {os.getpid()}). Falling back to Docling.")
                    raw = docling_converter_worker.convert(file_path).document.export_to_markdown()

            except Exception as e_miner:
                print(f"  └─ MinerU failed for {os.path.basename(file_path)} (PID: {os.getpid()}): {e_miner}. Falling back to Docling.")
                raw = docling_converter_worker.convert(file_path).document.export_to_markdown()
            finally:
                # Clean up temporary directory specific to this file and process
                if os.path.exists(temp_output_dir):
                    shutil.rmtree(temp_output_dir)

        elif ext in ['docx', 'pptx', 'xlsx', 'csv', 'jpg', 'png']:
            raw = markitdown_converter_worker.convert(file_path).text_content

        # AGGRESSIVE CLEANUP
        cleaned = aggressive_segmentation(raw)
        processed_content = f"\n--- SOURCE: {os.path.basename(file_path)} ---\n{cleaned}"

    except Exception as e:
        error_message = f"  ❌ Failed {os.path.basename(file_path)} (PID: {os.getpid()}): {e}"

    return processed_content, error_message, file_path

def run_integrated_pipeline_parallel(root_path, num_processes=None):
    """
    Runs the integrated file processing pipeline with parallel execution for files
    within each subfolder. num_processes=None uses os.cpu_count().
    """
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M")

    # Create a base directory for all temporary MinerU outputs, to be cleaned up after all processing
    base_temp_miner_output_dir = '/content/temp_miner_output'
    os.makedirs(base_temp_miner_output_dir, exist_ok=True)

    try:
        # Initialize a multiprocessing Pool with an initializer for worker setup
        with multiprocessing.Pool(processes=num_processes, initializer=worker_init) as pool:
            for root, dirs, files in os.walk(root_path):
                files_to_process_paths = [os.path.join(root, f) for f in files if not f.endswith('.md')]
                if not files_to_process_paths: continue

                subfolder_name = os.path.basename(root)
                output_path = os.path.join(root, f"{subfolder_name}_consolidated_{timestamp}.md")

                batch_content = [f"# FOLDER: {subfolder_name}\n# GENERATED: {timestamp}\n"]

                print(f"Processing folder: {subfolder_name} with {len(files_to_process_paths)} files in parallel...")

                # Use pool.map to process files in parallel.
                # map preserves the order of results corresponding to the input iterable.
                results = pool.map(process_single_file, files_to_process_paths)

                for processed_content, error_message, original_file_path in results:
                    if processed_content:
                        batch_content.append(processed_content)
                    elif error_message:
                        print(error_message) # Print errors that occurred during processing

                if len(batch_content) > 1: # Only write if actual content was processed beyond the header
                    with open(output_path, 'w', encoding='utf-8') as f:
                        f.writelines(batch_content)
                    print(f"✅ Consolidated: {subfolder_name}")
    finally:
        # Ensure the base temporary MinerU output directory is cleaned up after all tasks are done
        if os.path.exists(base_temp_miner_output_dir):
            shutil.rmtree(base_temp_miner_output_dir)

# Call the parallel pipeline
run_integrated_pipeline_parallel('/content/drive/MyDrive/Stock_Market/Indian Economic Survey')

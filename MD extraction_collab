# This function needs to be at the top level for multiprocessing to pickle it
def aggressive_segmentation(text):
    """Force-splits merged words to fix 'smushed' text."""
    # Ensure wordsegment's dictionary is loaded for the worker, if not already.
    from wordsegment import segment, load, default_dictionary
    if default_dictionary is None:
        load()

    def fix_line(line):
        words = line.split()
        new_words = []
        for w in words:
            clean_w = re.sub(r'[^a-zA-Z]', '', w)
            if len(clean_w) > 7 or (len(clean_w) > 1 and any(c.isupper() for c in clean_w[1:])):
                new_words.append(" ".join(segment(clean_w)))
            else:
                new_words.append(w)
        return " ".join(new_words)
    return "\n".join([fix_line(l) for l in text.split('\n')])

# Function to initialize worker processes (e.g., load wordsegment's dictionary)

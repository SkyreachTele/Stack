import os
import gc
import time
import torch
from pathlib import Path

try:
    from google.colab import drive
except ImportError:
    pass

from docling.document_converter import DocumentConverter
from docling.datamodel.pipeline_options import PdfPipelineOptions
from docling.datamodel.base_models import InputFormat
from docling.document_converter import PdfFormatOption
import pypdfium2 as pdfium

# 2. Mount Google Drive
if not os.path.exists('/content/drive'):
    drive.mount('/content/drive')

# ── Configuration ─────────────────────────────────────────────────────
parent_dir = Path("/content/drive/My Drive/Stock_Market/Indian Economic Survey")
SKIP_FOLDERS = ["FY_2025", "FY_2026"]
IGNORE_PATTERNS = (
    "epreface", "hechap", "hepreface", "hechapter",
    "infographics", "statistical-appendix-in-hindi", "tab"
)

def should_skip(filename):
    fname = filename.lower()
    if any(p in fname for p in IGNORE_PATTERNS):
        if "echapter" in fname: return False
        return True
    if "echap" in fname and "echapter" not in fname: return True
    return False

def make_converter():
    opts = PdfPipelineOptions()
    opts.do_ocr = True
    opts.do_table_structure = True
    # Use GPU for RapidOCR
    opts.accelerator.device = "cuda" if torch.cuda.is_available() else "cpu"
    return DocumentConverter(
        format_options={InputFormat.PDF: PdfFormatOption(pipeline_options=opts)}
    )

converter = make_converter()

# ── Global Processing ──────────────────────────────────────
if parent_dir.exists():
    subfolders = sorted([d for d in parent_dir.iterdir() if d.is_dir()])
    
    for folder in subfolders:
        if folder.name in SKIP_FOLDERS: continue

        master_filename = f"{folder.name}_master.md"
        master_out = folder / master_filename
        
        # If master exists, skip session
        if master_out.exists():
            print(f"[SKIP SESSION] {folder.name} (Done)")
            continue

        pdf_files = sorted(list(folder.glob("*.pdf")))
        if not pdf_files: continue

        print(f"\n{'='*60}\nRUNNING SESSION: {folder.name}\n{'='*60}")
        folder_markdown = []

        for pdf_path in pdf_files:
            filename = pdf_path.name
            if should_skip(filename): continue

            # Internal Resume: Check if file already added to markdown list conceptually
            # For simplicity, we process the whole folder at once into the master file
            print(f"\n[START] {filename}")
            folder_markdown.append(f"\n\n# SOURCE: {filename}\n")

            try:
                doc = pdfium.PdfDocument(str(pdf_path))
                total_pages = len(doc)
                doc.close()

                for pg in range(1, total_pages + 1):
                    pg_start = time.time()
                    print(f"  Page {pg}/{total_pages} ...", end="", flush=True)

                    result = converter.convert(str(pdf_path), page_range=(pg, pg))
                    content = result.document.export_to_markdown()
                    folder_markdown.append(content)

                    elapsed = time.time() - pg_start
                    print(f" [{elapsed:.1f}s] ✓", end=" ")

                    gc.collect()
                    if torch.cuda.is_available(): torch.cuda.empty_cache()

                print(f"\n[COMPLETED] {filename}")
            except Exception as e:
                print(f"\n[ERROR] {filename}: {e}")

        if folder_markdown:
            master_out.write_text("\n".join(folder_markdown), encoding="utf-8")
            print(f"\n[FINISHED SESSION] {folder.name}. Saved to: {master_out}")

    print(f"\n{'#'*60}\nALL SESSIONS PROCESSED\n{'#'*60}")
else:
    print(f"Error: Path {parent_dir} not found.")
